# Backend Configuration
APP_NAME="AI Cultural Travel Companion"
APP_VERSION="1.0.0"
DEBUG=true

# API Keys (Replace with actual keys)
GOOGLE_API_KEY=""
GOOGLE_MAPS_API_KEY=""
GOOGLE_PLACES_API_KEY=""
GEMINI_API_KEY=""

# Firebase Configuration
FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY_ID=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_CLIENT_ID=""
FIREBASE_AUTH_URI="https://accounts.google.com/o/oauth2/auth"
FIREBASE_TOKEN_URI="https://oauth2.googleapis.com/token"

# Database
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/travel_companion"
# For local development with SQLite
# DATABASE_URL="sqlite+aiosqlite:///./travel_companion.db"

# Redis
REDIS_URL="redis://localhost:6379/0"

# JWT
SECRET_KEY="your-super-secret-key-change-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001", "http://127.0.0.1:3000"]

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Google Maps / Places API
GOOGLE_MAPS_BASE_URL="https://maps.googleapis.com/maps/api"
GOOGLE_PLACES_BASE_URL="https://places.googleapis.com/v1"

# Gemini
GEMINI_MODEL="gemini-1.5-pro"
GEMINI_FLASH_MODEL="gemini-1.5-flash"
GEMINI_EMBEDDING_MODEL="text-embedding-004"

# External APIs
TICKETMASTER_API_KEY=""
EVENTBRITE_API_KEY=""
OPENWEATHER_API_KEY=""

# Email (optional)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
EMAILS_FROM_EMAIL=""
EMAILS_FROM_NAME="AI Cultural Travel Companion"

# Frontend URL
FRONTEND_URL="http://localhost:3000"